---
layout: null
permalink: /search.json
---
[
{% for post in site.posts %}
  {% capture post_content %}{{ post.content | strip_html | strip_newlines | replace: '  ', ' ' | replace: '  ', ' ' | strip }}{% endcapture %}
  {% capture post_excerpt %}{{ post.excerpt | default: post.content | strip_html | strip_newlines | replace: '  ', ' ' | replace: '  ', ' ' | strip | truncate: 220 }}{% endcapture %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "category": {{ post.category | default: "" | jsonify }},
    "tags": {{ post.tags | jsonify }},
    "location": {{ post.location | default: "" | jsonify }},
    "excerpt": {{ post_excerpt | jsonify }},
    "content": {{ post_content | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
