{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New Circadia Post",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "newpost",
        "${input:title}",
        "--",
        "--image",
        "${input:image}",
        "--text",
        "${input:text}",
        "--layout",
        "${input:layout}",
        "--category",
        "${input:category}",
        "--tags",
        "${input:tags}",
        "--mode",
        "${input:mode}",
        "--location",
        "${input:location}",
        "--weather",
        "${input:weather}",
        "--temperature",
        "${input:temperature}",
        "--light",
        "${input:light}",
        "--gear",
        "${input:gear}",
        "--project",
        "${input:project}",
        "--stage",
        "${input:stage}",
        "--parts",
        "${input:parts}",
        "--changes",
        "${input:changes}",
        "--lessons",
        "${input:lessons}",
        "--alt",
        "${input:alt}",
        "${input:useExifFlag}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Publish Circadia Post",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "publishpost",
        "--",
        "${input:commitMessage}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "title",
      "type": "promptString",
      "description": "Post title"
    },
    {
      "id": "image",
      "type": "command",
      "command": "extension.commandvariable.file.openDialog",
      "args": {
        "canSelect": "files",
        "defaultUri": "C:\\Users\\terb0\\Downloads\\PostImages",
        "title": "Select an image for the new Circadia post",
        "openLabel": "Use this image",
        "filters": {
          "Images": [
            "jpg",
            "jpeg",
            "png",
            "gif",
            "webp",
            "avif"
          ]
        }
      }
    },
    {
      "id": "text",
      "type": "promptString",
      "description": "Post body text"
    },
    {
      "id": "layout",
      "type": "pickString",
      "description": "Post layout",
      "default": "post",
      "options": [
        "post",
        "build"
      ]
    },
    {
      "id": "category",
      "type": "pickString",
      "description": "Category or auto-detect",
      "default": "auto",
      "options": [
        "auto",
        "gardening",
        "rc-crawling",
        "fpv",
        "photography",
        "amateur-radio",
        "motorcycling",
        "camping",
        "marksmanship"
      ]
    },
    {
      "id": "tags",
      "type": "promptString",
      "description": "Optional tags, comma-separated",
      "default": ""
    },
    {
      "id": "mode",
      "type": "pickString",
      "description": "Optional mode",
      "default": "",
      "options": [
        "",
        "build",
        "explore",
        "test",
        "maintain",
        "observe"
      ]
    },
    {
      "id": "location",
      "type": "promptString",
      "description": "Optional location",
      "default": ""
    },
    {
      "id": "weather",
      "type": "promptString",
      "description": "Optional weather",
      "default": ""
    },
    {
      "id": "temperature",
      "type": "promptString",
      "description": "Optional temperature",
      "default": ""
    },
    {
      "id": "light",
      "type": "promptString",
      "description": "Optional light conditions",
      "default": ""
    },
    {
      "id": "gear",
      "type": "promptString",
      "description": "Optional gear list, separate items with |",
      "default": ""
    },
    {
      "id": "project",
      "type": "promptString",
      "description": "Optional build project name",
      "default": ""
    },
    {
      "id": "stage",
      "type": "promptString",
      "description": "Optional build stage",
      "default": ""
    },
    {
      "id": "parts",
      "type": "promptString",
      "description": "Optional build parts list, separate items with |",
      "default": ""
    },
    {
      "id": "changes",
      "type": "promptString",
      "description": "Optional build changes list, separate items with |",
      "default": ""
    },
    {
      "id": "lessons",
      "type": "promptString",
      "description": "Optional build lessons list, separate items with |",
      "default": ""
    },
    {
      "id": "alt",
      "type": "promptString",
      "description": "Optional image alt text",
      "default": ""
    },
    {
      "id": "useExifFlag",
      "type": "pickString",
      "description": "Optional EXIF helper",
      "default": "",
      "options": [
        "",
        "--use-exif"
      ]
    },
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Commit message",
      "default": "Add new Circadia post"
    }
  ]
}
